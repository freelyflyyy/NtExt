# === CMake 产生的中间文件 ===
# 忽略所有名为 build 的构建目录（如 NtCallExt/build/）
build/
# 忽略 Visual Studio 默认的 CMake 构建输出目录
out/
# 忽略 CMake 自动生成的缓存和脚本
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
install/
Makefile
#忽略gitignore文件
.gitignore
.gitattributes
# 忽略 Ninja 构建生成的日志
.ninja_deps
.ninja_log
build.ninja

# === Visual Studio 产生的临时文件 ===
.vs/
*.sln
*.vcxproj
*.filters
*.user
*.suo
*.db
*.opendb

# === 编译生成的二进制文件 (Windows/MSVC) ===
# 静态库和导入库
*.lib
# 动态链接库
*.dll
# 可执行文件
*.exe
# 调试符号和中间文件
*.pdb
*.obj
*.ilk
*.exp
*.res
*.tlog
*.lastbuildstate

# === 预编译头相关 (PCH) ===
# 忽略 MSVC 生成的二进制预编译头文件
*.pch

# === 配置文件 (不应忽略的例外) ===
# 注意：不要忽略 CMakePresets.json，但通常会忽略用户私有的预设文件
CMakeUserPresets.json

# === 操作系统临时文件 ===
Thumbs.db
.DS_Store